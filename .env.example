# =============================================================================
# Cerberus Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Backend ---

# Redis connection URL
CERBERUS_REDIS_URL=redis://redis:6379/0

# PostgreSQL connection URL (async driver)
CERBERUS_DATABASE_URL=postgresql+asyncpg://cerberus:cerberus@postgres:5432/cerberus

# Admin API key for tenant management endpoints
# CHANGE THIS in production. Seriously.
CERBERUS_ADMIN_API_KEY=cerberus-admin-dev-key

# Log level: debug, info, warning, error
CERBERUS_LOG_LEVEL=info

# CORS allowed origins (comma-separated)
CERBERUS_CORS_ORIGINS=http://localhost:3000

# --- Postgres ---

# Used by the postgres container on first boot
POSTGRES_USER=cerberus
POSTGRES_PASSWORD=cerberus
POSTGRES_DB=cerberus

# --- Grafana ---

# Grafana admin password (for the web UI)
GRAFANA_PASSWORD=cerberus

# --- Production only ---

# Set strong passwords for production deployments:
# POSTGRES_PASSWORD=your-secure-password-here
# GRAFANA_PASSWORD=your-secure-password-here
# CERBERUS_ADMIN_API_KEY=your-secure-admin-key-here
