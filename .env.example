# =============================================================================
# Cerberus Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Backend ---

# Redis connection URL
# Local: redis://localhost:6379/0
# Upstash: rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
CERBERUS_REDIS_URL=redis://redis:6379/0

# PostgreSQL connection URL
# Local: postgresql+asyncpg://cerberus:cerberus@localhost:5432/cerberus
# Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/cerberus?sslmode=require
CERBERUS_DATABASE_URL=postgresql+asyncpg://cerberus:cerberus@postgres:5432/cerberus

# Admin API key for tenant management endpoints
# CHANGE THIS in production. Seriously.
CERBERUS_ADMIN_API_KEY=cerberus-admin-dev-key

# Log level: debug, info, warning, error
CERBERUS_LOG_LEVEL=info

# Environment: dev, staging, production
CERBERUS_ENVIRONMENT=dev

# Number of gunicorn workers (set to 2 on free tiers)
CERBERUS_WORKERS=4

# CORS allowed origins (comma-separated)
# CERBERUS_ALLOWED_ORIGINS=https://cerberus-app.vercel.app,http://localhost:3000

# --- Frontend ---

# Backend API URL (for Vercel rewrites / client-side calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Postgres (docker-compose only) ---

POSTGRES_USER=cerberus
POSTGRES_PASSWORD=cerberus
POSTGRES_DB=cerberus

# --- Grafana (docker-compose only) ---

GRAFANA_PASSWORD=cerberus
